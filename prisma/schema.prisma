// MyNigerianGuide — Core Database Schema
// Source: Product & Technical Brief v3.0, Section 19
// Table names are snake_case via @@map; fields stay camelCase
// (Prisma convention) so generated client code reads naturally.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- Enums ----------

enum Role {
  USER
  ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  BANNED
  DELETED
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
  REVOKED
}

enum KeywordStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum KeywordSource {
  YELLOW_PAGES
  NIGERIA_SPECIFIC
  USER_SUBMITTED
}

enum ReportEntityType {
  POST
  REVIEW
  BUSINESS_PAGE
  USER
}

enum ReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum PlacementType {
  TOP_OF_SEARCH
  FEATURED_BADGE
}

enum MediaEntityType {
  BUSINESS_PAGE
  POST
  USER
}

enum LocationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LocationSource {
  SEEDED
  USER_SUBMITTED
}

// ---------- Core identity ----------

model User {
  id            String        @id
  email         String        @unique
  name          String?
  username      String?       @unique
  bio           String?
  avatarUrl     String?
  city          String?
  state         String?
  emailVerified Boolean       @default(false)
  accountStatus AccountStatus @default(ACTIVE)
  role          Role          @default(USER)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  adminUser              AdminUser?
  businessPages          BusinessPage[]
  posts                  Post[]
  follows                Follow[]
  reviews                Review[]
  comments               Comment[]
  postLikes              PostLike[]
  notifications          Notification[]
  searchQueries          SearchQuery[]
  pageViews              PageView[]
  auditLogs              AuditLog[]
  submittedTowns         Town[]
  submittedKeywords      Keyword[]              @relation("SubmittedKeywords")
  submittedCategories    Category[]             @relation("SubmittedCategories")
  reportsFiled           Report[]               @relation("ReporterReports")
  reportsResolved        Report[]               @relation("ResolvedReports")
  verificationsReviewed  VerificationRequest[]  @relation("ReviewedVerifications")
  adminsCreated          AdminUser[]            @relation("CreatedByAdmin")
  rolesAssigned          UserRole[]             @relation("RoleAssignedBy")
  adCreativesReviewed    AdCampaign[]           @relation("ReviewedAdCreative")
  adPriceOverridesSet    AdPriceOverride[]      @relation("SetAdPriceOverride")

  @@map("users")
}

// AdminUser now only marks "is this person any kind of admin at all" via
// isActive. WHICH admin capabilities they hold lives entirely in the
// roles/permissions system below (userRoles -> AdminRoleTemplate ->
// RolePermission -> Permission) — the old single adminRole enum field has
// been removed in favour of this permissions-first model, agreed this
// session, so one person can hold multiple roles (e.g. Verification
// Officer AND Moderation Officer) rather than being limited to exactly
// one fixed role.
model AdminUser {
  id          String      @id @default(uuid())
  userId      String      @unique
  user        User        @relation(fields: [userId], references: [id])
  isActive    Boolean     @default(true)
  createdById String?
  createdBy   User?       @relation("CreatedByAdmin", fields: [createdById], references: [id])
  createdAt   DateTime    @default(now())

  userRoles   UserRole[]

  @@map("admin_users")
}

// A single, specific capability — named module.action (e.g. business.verify,
// review.moderate) so the list stays navigable as MNG grows into more
// modules (government services, marketplace, events, etc per the founder's
// long-term vision) without the permission list becoming an unstructured
// mess. This is the source of truth for all admin authorization.
model Permission {
  id          String   @id @default(uuid())
  key         String   @unique
  module      String
  description String
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@index([module])
  @@map("permissions")
}

// A reusable, named bundle of permissions — a template, not a hardcoded
// enum. isSystemRole protects the 5 brief-defined starter roles (Super
// Admin, Operations Manager, Verification Officer, Moderation Officer,
// Support Agent) from accidental deletion/rename, while still allowing
// genuinely custom roles to be created later with zero schema changes.
model AdminRoleTemplate {
  id           String   @id @default(uuid())
  name         String   @unique
  description  String?
  isSystemRole Boolean  @default(false)
  createdAt    DateTime @default(now())

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model RolePermission {
  roleId       String
  role         AdminRoleTemplate @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// Which roles a given admin user holds — deliberately many-to-many so one
// person can hold multiple roles at once. Per-user permission overrides
// (grant/revoke individual permissions outside of roles) were deliberately
// deferred until a genuine business need arises — this schema can support
// adding a UserPermission table later without touching anything here.
model UserRole {
  adminUserId  String
  adminUser    AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  roleId       String
  role         AdminRoleTemplate @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedAt   DateTime  @default(now())
  assignedById String?
  assignedBy   User?     @relation("RoleAssignedBy", fields: [assignedById], references: [id])

  @@id([adminUserId, roleId])
  @@map("user_roles")
}

// ---------- Location hierarchy ----------

model State {
  id   String @id @default(uuid())
  name String @unique
  slug String @unique

  localGovernments LocalGovernment[]
  businessPages    BusinessPage[]

  @@map("states")
}

model LocalGovernment {
  id      String @id @default(uuid())
  name    String
  slug    String
  stateId String
  state   State  @relation(fields: [stateId], references: [id])

  towns         Town[]
  businessPages BusinessPage[]
  adCampaignTargets AdCampaignTarget[]
  adPriceOverrides  AdPriceOverride[]

  @@unique([stateId, name])
  @@map("local_governments")
}

model Town {
  id                String          @id @default(uuid())
  name              String
  slug              String
  localGovernmentId String
  localGovernment   LocalGovernment @relation(fields: [localGovernmentId], references: [id])
  status            LocationStatus  @default(APPROVED)
  source            LocationSource  @default(SEEDED)
  submittedByUserId String?
  submittedBy       User?           @relation(fields: [submittedByUserId], references: [id])
  createdAt         DateTime        @default(now())

  businessPages BusinessPage[]

  @@unique([localGovernmentId, name])
  @@map("towns")
}

// ---------- Taxonomy ----------

model Category {
  id                String         @id @default(uuid())
  name              String
  slug              String         @unique
  icon              String?
  description       String?
  isActive          Boolean        @default(true)
  status            LocationStatus @default(APPROVED)
  source            LocationSource @default(SEEDED)
  submittedByUserId String?
  submittedBy       User?          @relation("SubmittedCategories", fields: [submittedByUserId], references: [id])

  keywords      Keyword[]
  businessPages BusinessPage[]

  @@map("categories")
}

model Keyword {
  id                String        @id @default(uuid())
  name              String
  slug              String        @unique
  categoryId        String
  category          Category      @relation(fields: [categoryId], references: [id])
  status            KeywordStatus @default(PENDING)
  source            KeywordSource @default(USER_SUBMITTED)
  isNigeriaSpecific Boolean       @default(false)
  usageCount        Int           @default(0)
  submittedByUserId String?
  submittedBy       User?         @relation("SubmittedKeywords", fields: [submittedByUserId], references: [id])
  createdAt         DateTime      @default(now())

  businessKeywords  BusinessKeyword[]
  sponsoredListings SponsoredListing[]
  adCampaignTargets AdCampaignTarget[]
  adPriceOverrides  AdPriceOverride[]

  @@index([name])
  @@index([status])
  @@index([usageCount])
  @@map("keywords")
}

// ---------- Business pages ----------

model BusinessPage {
  id                   String              @id @default(uuid())
  ownerUserId          String
  owner                User                @relation(fields: [ownerUserId], references: [id])
  name                 String
  slug                 String              @unique
  categoryId           String
  category             Category            @relation(fields: [categoryId], references: [id])
  description          String?
  address              String?
  stateId              String
  state                State               @relation(fields: [stateId], references: [id])
  localGovernmentId    String
  localGovernment      LocalGovernment     @relation(fields: [localGovernmentId], references: [id])
  townId               String?
  town                 Town?               @relation(fields: [townId], references: [id])
  latitude             Float?
  longitude            Float?
  phone                String?
  email                String?
  website              String?
  whatsapp             String?
  hours                Json?
  verificationStatus   VerificationStatus  @default(UNVERIFIED)
  completenessScore    Int                 @default(0)
  averageRating        Float               @default(0)
  isClaimed            Boolean             @default(false)
  isPublished          Boolean             @default(false)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  businessKeywords     BusinessKeyword[]
  posts                Post[]
  follows               Follow[]
  reviews               Review[]
  media                Media[]
  verificationRequests VerificationRequest[]
  sponsoredListings    SponsoredListing[]
  adCampaigns          AdCampaign[]
  pageViews            PageView[]

  @@index([stateId, localGovernmentId, townId])
  @@map("business_pages")
}

model BusinessKeyword {
  businessPageId String
  businessPage   BusinessPage @relation(fields: [businessPageId], references: [id])
  keywordId      String
  keyword        Keyword      @relation(fields: [keywordId], references: [id])

  @@id([businessPageId, keywordId])
  @@map("business_keywords")
}

// ---------- Social layer ----------

model Post {
  id              String       @id @default(uuid())
  businessPageId  String
  businessPage    BusinessPage @relation(fields: [businessPageId], references: [id])
  authorUserId    String
  author          User         @relation(fields: [authorUserId], references: [id])
  content         String
  mediaUrls       String[]
  isHidden        Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  comments        Comment[]
  likes           PostLike[]

  @@map("posts")
}

model Comment {
  id           String   @id @default(uuid())
  postId       String
  post         Post     @relation(fields: [postId], references: [id])
  authorUserId String
  author       User     @relation(fields: [authorUserId], references: [id])
  content      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([postId])
  @@map("comments")
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([postId])
  @@map("post_likes")
}

model Follow {
  id              String       @id @default(uuid())
  followerUserId  String
  follower        User         @relation(fields: [followerUserId], references: [id])
  businessPageId  String
  businessPage    BusinessPage @relation(fields: [businessPageId], references: [id])
  createdAt       DateTime     @default(now())

  @@unique([followerUserId, businessPageId])
  @@map("follows")
}

model Review {
  id              String       @id @default(uuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  businessPageId  String
  businessPage    BusinessPage @relation(fields: [businessPageId], references: [id])
  rating          Int
  body            String?
  ownerResponse   String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([userId, businessPageId])
  @@map("reviews")
}

model Media {
  id              String          @id @default(uuid())
  entityType      MediaEntityType
  businessPageId  String?
  businessPage    BusinessPage?   @relation(fields: [businessPageId], references: [id])
  url             String
  mediaType       String
  createdAt       DateTime        @default(now())

  @@map("media")
}

// ---------- Trust & safety ----------

model VerificationRequest {
  id              String              @id @default(uuid())
  businessPageId  String
  businessPage    BusinessPage        @relation(fields: [businessPageId], references: [id])
  cacNumber       String
  documentUrls    String[]
  status          VerificationStatus  @default(PENDING)
  reviewedById    String?
  reviewedBy      User?               @relation("ReviewedVerifications", fields: [reviewedById], references: [id])
  reviewNotes     String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@map("verification_requests")
}

model Report {
  id              String            @id @default(uuid())
  reporterUserId  String
  reporter        User              @relation("ReporterReports", fields: [reporterUserId], references: [id])
  entityType      ReportEntityType
  entityId        String
  reason          String
  status          ReportStatus      @default(OPEN)
  resolvedById    String?
  resolvedBy      User?             @relation("ResolvedReports", fields: [resolvedById], references: [id])
  createdAt       DateTime          @default(now())
  resolvedAt      DateTime?

  @@map("reports")
}

model AuditLog {
  id           String   @id @default(uuid())
  adminUserId  String
  adminUser    User     @relation(fields: [adminUserId], references: [id])
  action       String
  entityType   String
  entityId     String
  reason       String?
  metadata     Json?
  ipAddress    String?
  createdAt    DateTime @default(now())

  @@map("audit_log")
}

// ---------- Monetisation ----------

model SponsoredListing {
  id              String        @id @default(uuid())
  businessPageId  String
  businessPage    BusinessPage  @relation(fields: [businessPageId], references: [id])
  placementType   PlacementType
  keywordId       String?
  keyword         Keyword?      @relation(fields: [keywordId], references: [id])
  city            String?
  startDate       DateTime
  endDate         DateTime
  isActive        Boolean       @default(true)
  priceNaira      Int
  // The Paystack transaction reference that paid for this listing.
  // Unique at the database level so a webhook retry or a user revisiting
  // the callback URL can never create a second listing for the same
  // payment — this is the real idempotency guard, not a time-window
  // heuristic.
  paystackReference String?     @unique
  createdAt       DateTime      @default(now())

  @@map("sponsored_listings")
}

// Superseded by AdCampaign below for new purchases — kept in place as a
// historical record of the platform's first real sponsored listing
// payment, which was migrated into AdCampaign rather than deleted. Never
// write new rows here.

enum CreativeApprovalStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

// The new top-level unit for sponsored advertising, replacing the
// single-target SponsoredListing above. A business can run several of
// these simultaneously (founder's explicit decision), each with its own
// name, optional creative (image + caption — also founder's explicit
// decision, on top of the original placement-only brief scope), and one
// or more AdCampaignTarget rows for keyword+city combinations.
model AdCampaign {
  id                      String                 @id @default(uuid())
  businessPageId          String
  businessPage            BusinessPage           @relation(fields: [businessPageId], references: [id])
  name                    String
  placementType           PlacementType
  imageUrl                String?
  caption                 String?
  // NONE when there's no creative at all (placement-only campaign, no
  // image/caption) — distinct from PENDING, since a campaign with no
  // creative never needs admin review of anything.
  creativeApprovalStatus  CreativeApprovalStatus @default(NONE)
  creativeReviewNotes     String?
  creativeReviewedById    String?
  creativeReviewedBy      User?                  @relation("ReviewedAdCreative", fields: [creativeReviewedById], references: [id])
  creativeReviewedAt      DateTime?
  startDate               DateTime
  endDate                 DateTime
  totalPriceNaira         Int
  isActive                Boolean                @default(true)
  isPaused                Boolean                @default(false)
  paystackReference       String?                @unique
  createdAt               DateTime               @default(now())

  targets                 AdCampaignTarget[]

  @@map("ad_campaigns")
}

// One row per keyword+city combination chosen for a campaign. Each
// carries its own price at purchase time — campaign.totalPriceNaira is
// the sum of these — per the founder's explicit pricing decision (sum
// of combinations, not one flat campaign price covering everything
// chosen). impressionCount/clickCount back the performance reporting
// the founder asked for.
model AdCampaignTarget {
  id                String         @id @default(uuid())
  campaignId        String
  campaign          AdCampaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  keywordId         String
  keyword           Keyword        @relation(fields: [keywordId], references: [id])
  localGovernmentId String
  localGovernment   LocalGovernment @relation(fields: [localGovernmentId], references: [id])
  priceNaira        Int
  impressionCount   Int            @default(0)
  clickCount        Int            @default(0)
  createdAt         DateTime       @default(now())

  @@map("ad_campaign_targets")
}

// Admin-set fixed price overriding the competitiveness formula for a
// specific keyword and/or city, per the founder's explicit decision to
// keep the formula as the default with admin override capability on
// top. Either foreign key can be null: keywordId-only applies across all
// cities for that keyword, localGovernmentId-only applies across all
// keywords in that city, both-set applies to that exact combination
// only. fixedPriceNairaPer30Days is stored per-30-days and scaled to
// whatever duration is actually requested.
model AdPriceOverride {
  id                       String          @id @default(uuid())
  keywordId                String?
  keyword                  Keyword?        @relation(fields: [keywordId], references: [id])
  localGovernmentId        String?
  localGovernment          LocalGovernment? @relation(fields: [localGovernmentId], references: [id])
  fixedPriceNairaPer30Days Int
  setById                  String
  setBy                    User            @relation("SetAdPriceOverride", fields: [setById], references: [id])
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt

  @@map("ad_price_overrides")
}

// ---------- Notifications & analytics ----------

model Notification {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  type        String
  title       String
  body        String?
  isRead      Boolean  @default(false)
  entityType  String?
  entityId    String?
  createdAt   DateTime @default(now())

  @@map("notifications")
}

model SearchQuery {
  id          String   @id @default(uuid())
  query       String
  city        String?
  state       String?
  resultCount Int      @default(0)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())

  @@map("search_queries")
}

model PageView {
  id              String       @id @default(uuid())
  businessPageId  String
  businessPage    BusinessPage @relation(fields: [businessPageId], references: [id])
  userId          String?
  user            User?        @relation(fields: [userId], references: [id])
  ipHash          String?
  source          String?
  createdAt       DateTime     @default(now())

  @@map("page_views")
}
