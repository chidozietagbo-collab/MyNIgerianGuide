# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored — never commit real credentials.

# --- Supabase (Step 3) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Prisma / Database (Step 4) ---
# Prisma needs these in .env (not .env.local) as well — see Prisma section
# of the schema setup step for why.
DATABASE_URL=
DIRECT_URL=

# --- Google Maps (later milestone) ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Paystack (Milestone 6) ---
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# --- Site URL (used by Paystack callback redirects) ---
# Optional — falls back to the .vercel.app URL if not set.
NEXT_PUBLIC_SITE_URL=

# --- Vercel Cron (renewal reminders) ---
# CRON_SECRET is auto-provisioned by Vercel itself once vercel.json's
# crons config is deployed — you do NOT need to set this manually.

# --- Resend (later milestone) ---
RESEND_API_KEY=
